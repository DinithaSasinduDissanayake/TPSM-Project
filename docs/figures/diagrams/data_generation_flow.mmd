flowchart TD
    A[Config file<br/>defines tasks, datasets,<br/>model pairs, metrics, splits] --> B[Runner starts]
    B --> C{Task type}

    C --> C1[Classification]
    C --> C2[Regression]

    C1 --> D1[Pick one dataset]
    C2 --> D2[Pick one dataset]

    D1 --> E1[Load raw dataset<br/>from file or URL]
    D2 --> E2[Load raw dataset<br/>from file or URL]

    E1 --> F1[Clean and prepare data]
    E2 --> F2[Clean and prepare data]

    F1 --> G1[Create repeated k-fold splits]
    F2 --> G2[Create repeated k-fold splits]

    G1 --> H1[For each split,<br/>train single models and ensemble models]
    G2 --> H2[For each split,<br/>train single models and ensemble models]

    H1 --> I1[Measure metrics<br/>for every model]
    H2 --> I2[Measure metrics<br/>for every model]

    I1 --> J1[Compare model pairs<br/>on same split]
    I2 --> J2[Compare model pairs<br/>on same split]

    J1 --> K[Write final artifacts]
    J2 --> K

    K --> L1[model_runs.csv<br/>all model results]
    K --> L2[pairwise_differences.csv<br/>single vs ensemble on same split]
    K --> L3[warnings_report.json<br/>quality warnings]
    K --> L4[failed_datasets.csv<br/>datasets that timed out or failed]
    K --> L5[run_log.txt and run_state.json<br/>progress and resumable state]

    classDef artifact fill:#E6F4EA,stroke:#2E7D32,color:#1B5E20,stroke-width:1.5px;
    classDef phase fill:#E8F0FE,stroke:#1565C0,color:#0D47A1,stroke-width:1.5px;
    classDef choice fill:#FFF4E5,stroke:#EF6C00,color:#E65100,stroke-width:1.5px;

    class A,B,D1,D2,E1,E2,F1,F2,G1,G2,H1,H2,I1,I2,J1,J2,K phase;
    class C choice;
    class L1,L2,L3,L4,L5 artifact;
